APP_PORT=8080
DATABASE_URL=postgres://lapangango_user:lapangango_password@localhost:5432/lapangango_db?sslmode=disable
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change_me_for_local_development
JWT_EXPIRES_IN_HOURS=24
BOOKING_PAYMENT_TTL_MINUTES=30
BOOKING_EXPIRY_SWEEP_INTERVAL_SECONDS=60
GENERAL_RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=100

# Staff invite/reset email delivery
FRONTEND_BASE_URL=http://localhost:3000
EMAIL_DELIVERY_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_NAME=LapangGo
SMTP_FROM_EMAIL=no-reply@lapanggo.local

# Local Mailpit example:
# EMAIL_DELIVERY_ENABLED=true
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USE_TLS=false

# Production SMTP examples:
# Port 587: SMTP_USE_TLS=true uses STARTTLS.
# Port 465: SMTP_USE_TLS=true uses implicit TLS.
